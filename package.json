{
  "name": "star-wanderer-ai",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production node .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint",
    "type-check": "tsc --noEmit --pretty false",
    "check:victory": "node --no-warnings --experimental-strip-types scripts/check-victory-paths.mjs",
    "check:reputation": "node --no-warnings --experimental-strip-types scripts/check-reputation-ripple.mjs",
    "check:assignments": "node --no-warnings --experimental-strip-types scripts/check-assignment-fatigue.mjs",
    "check:events": "node --no-warnings --experimental-strip-types scripts/check-random-event-chains.mjs",
    "check:market": "node --no-warnings --experimental-strip-types scripts/check-market-tick.mjs",
    "check:contract-targets": "node --no-warnings --experimental-strip-types scripts/check-contract-targets.mjs",
    "check:expedition-environments": "node --no-warnings --experimental-strip-types scripts/check-expedition-environments.mjs",
    "check:expedition-orbital-scan": "node scripts/check-expedition-orbital-scan.mjs",
    "check:expedition-ruins": "node --no-warnings --experimental-strip-types scripts/check-expedition-ruins.mjs",
    "check:research-abilities": "node --no-warnings --experimental-strip-types scripts/check-research-special-abilities.mjs",
    "check:sector-readiness": "node --no-warnings --experimental-strip-types scripts/check-sector-readiness.mjs",
    "check:crew-layout": "node --no-warnings --experimental-strip-types scripts/check-crew-layout.mjs",
    "check:new-game": "node --no-warnings --experimental-strip-types scripts/check-new-game-setup.mjs",
    "check:dev-template": "NODE_ENV=development node --no-warnings --experimental-strip-types scripts/check-new-game-setup.mjs && NODE_ENV=production node --no-warnings --experimental-strip-types scripts/check-new-game-setup.mjs",
    "check:enemy-progression": "node --no-warnings --experimental-strip-types scripts/check-enemy-progression.mjs",
    "check:economy": "node --no-warnings --experimental-strip-types scripts/check-campaign-economy.mjs",
    "check:income": "node --no-warnings --experimental-strip-types scripts/check-income-sources.mjs",
    "check:space-monsters": "node --no-warnings --experimental-strip-types scripts/check-space-monsters.mjs",
    "check:distress-signals": "node --no-warnings --experimental-strip-types scripts/check-distress-signals.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.6",
    "immer": "^11.1.15",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.10",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
